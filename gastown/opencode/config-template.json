{
  "$schema": "https://opencode.ai/config.json",
  "model": "{{DEFAULT_MODEL}}",
  "provider": {
    "{{PROVIDER_ID}}": {
      "api": "{{PROVIDER_API_URL}}",
      "name": "{{PROVIDER_NAME}}",
      "env": ["{{PROVIDER_API_KEY_ENV}}"],
      "models": {
        "{{MODEL_ID_TURBO}}": {
          "id": "{{MODEL_ID_TURBO}}",
          "name": "{{MODEL_NAME_TURBO}}",
          "tool_call": true
        },
        "{{MODEL_ID_BASE}}": {
          "id": "{{MODEL_ID_BASE}}",
          "name": "{{MODEL_NAME_BASE}}",
          "tool_call": true
        }
      }
    }
  },
  "mcp": {
    "open-brain": {
      "type": "remote",
      "url": "{{OPENBRAIN_URL}}"
    }
  }
}
