{
  "$schema": "https://opencode.ai/config.json",
  "model": "{{MODEL_PLACEHOLDER}}",
  "provider": {
    "{{PROVIDER_ID}}": {
      "api": "{{PROVIDER_API_URL}}",
      "name": "{{PROVIDER_NAME}}",
      "env": ["{{PROVIDER_API_KEY_ENV}}"],
      "models": {
        "{{MODEL_ID}}": {
          "id": "{{MODEL_ID}}",
          "name": "{{MODEL_NAME}}",
          "tool_call": true
        }
      }
    }
  },
  "mcp": {
    "open-brain": {
      "type": "remote",
      "url": "{{OPENBRAIN_URL_PLACEHOLDER}}"
    }
  }
}
